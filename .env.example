# ========================
# Database
# ========================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ========================
# ProxyCLI AI 代理
# ========================
AI_PROXY_HOST=cli.twloop.com
AI_PROXY_PORT=443
AI_PROXY_TLS=true
AI_PROXY_TOKEN=
AI_PROXY_PROJECT=
AI_PROXY_GROUP=
AI_PROXY_AUTO_ROUTE=true
AI_PROXY_FALLBACK=true

AI_PROXY_REST_URL=http://cli.twloop.com:8080

# ========================
# Cloudflare R2 (媒體儲存)
# ========================
# 從 Cloudflare Dashboard → R2 → Manage API Tokens 建立
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=socialbot-media
# 公開 URL(R2 bucket 開放 public,或綁定自訂域名)
R2_PUBLIC_URL=https://media.socialbot.looptw.com

# ========================
# OAuth 社群帳號
# ========================
# redirect_uri 預設從 NEXT_PUBLIC_APP_URL 推導：
#   {NEXT_PUBLIC_APP_URL}/api/oauth/{platform}/callback
# 想為某個平台單獨覆寫 → 填下方對應的 {PLATFORM}_REDIRECT_URI

# Meta (Facebook + Instagram) — https://developers.facebook.com/apps
META_APP_ID=
META_APP_SECRET=
# META_REDIRECT_URI=

# Threads — https://developers.facebook.com/docs/threads
THREADS_APP_ID=
THREADS_APP_SECRET=
# THREADS_REDIRECT_URI=

# X (Twitter) — https://developer.x.com/en/portal/dashboard
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# TWITTER_REDIRECT_URI=

# X 每日發文 cap（防 pay-per-use 爆預算；0 = 關閉）
X_DAILY_POST_CAP=50

# ========================
# Cron 排程觸發 secret
# ========================
# Oracle crontab 用這個 secret 打 /api/cron/publish-due
CRON_SECRET=

# ========================
# Next.js
# ========================
# 本機 3100（不是預設 3000）；正式改 https://socialbot.looptw.com
NEXT_PUBLIC_APP_URL=http://localhost:3100
